generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  HELPDESK
}

enum ChatSessionStatus {
  ACTIVE
  RESOLVED
  ESCALATED
}

enum MessageSender {
  USER
  AI
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum EmailStatus {
  SENT
  FAILED
}

enum FeedbackRating {
  UP
  DOWN
}

enum KnowledgeCandidateStatus {
  PENDING
  NEEDS_EDIT
  APPROVED
  REJECTED
}

enum RedactionStatus {
  PENDING
  REDACTED
}

model User {
  id                String             @id @default(uuid())
  employeeId        String             @unique
  name              String
  email             String             @unique
  passwordHash      String
  role              UserRole           @default(USER)
  department        String?
  theme             String             @default("system")
  defaultChatMode   String             @default("normal")
  compactSidebar    Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  chatSessions      ChatSession[]
  uploadedFiles     UploadedFile[]
  escalationTickets EscalationTicket[]

  @@index([role])
}

model IssueCategory {
  id                 String               @id @default(uuid())
  name               String               @unique
  description        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  chatSessions       ChatSession[]
  knowledgeDocuments KnowledgeDocument[]
  escalationTickets  EscalationTicket[]
}

model ChatSession {
  id                String             @id @default(uuid())
  userId            String
  categoryId        String?
  title             String
  status            ChatSessionStatus  @default(ACTIVE)
  archived          Boolean            @default(false)
  isTemporary       Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          IssueCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages          ChatMessage[]
  escalationTickets EscalationTicket[]

  @@index([userId, createdAt])
  @@index([categoryId])
  @@index([status])
  @@index([archived])
  @@index([deletedAt])
}

model ChatMessage {
  id              String         @id @default(uuid())
  sessionId       String
  sender          MessageSender
  messageText     String         @db.Text
  imageId         String?
  confidenceScore Float?
  responseTimeMs  Int?
  feedback        FeedbackRating?
  feedbackComment String?        @db.Text
  predictedCategoryId String?
  predictedConfidence Float?
  editedAt        DateTime?
  createdAt       DateTime       @default(now())
  session         ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  image           UploadedFile?  @relation(fields: [imageId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([sender])
  @@index([feedback])
}

model UploadedFile {
  id           String        @id @default(uuid())
  userId       String
  originalName String
  storedName   String        @unique
  mimeType     String
  size         Int
  storagePath  String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([userId, createdAt])
}

model KnowledgeDocument {
  id                 String              @id @default(uuid())
  categoryId         String?
  title              String
  source             String?
  content            String              @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  category           IssueCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  chunks             KnowledgeChunk[]
  suggestedQuestions SuggestedQuestion[]

  @@index([categoryId])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String                 @id @default(uuid())
  documentId String
  chunkText  String                 @db.Text
  embedding  Unsupported("vector(768)")?
  metadata   Json?
  createdAt  DateTime               @default(now())
  document   KnowledgeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model SuggestedQuestion {
  id         String             @id @default(uuid())
  documentId String?
  question   String
  category   String?
  createdAt  DateTime           @default(now())
  document   KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([category])
}

model EscalationTicket {
  id        String          @id @default(uuid())
  ticketNumber Int         @unique @default(autoincrement())
  sessionId String
  userId    String
  categoryId String?
  summary   String          @db.Text
  status    TicketStatus    @default(OPEN)
  priority  TicketPriority  @default(MEDIUM)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  IssueCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  emailLogs EmailLog[]

  @@index([sessionId])
  @@index([userId])
  @@index([categoryId])
  @@index([status])
}

model EmailLog {
  id             String            @id @default(uuid())
  ticketId       String?
  recipientEmail String
  subject        String
  status         EmailStatus
  sentAt         DateTime          @default(now())
  ticket         EscalationTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([status])
}

// Stores trained ML model artifacts (Naive Bayes params, TF-IDF vocab, etc.)
// as JSON so models persist across restarts and can be retrained on demand.
model MlModel {
  id          String   @id @default(uuid())
  name        String   @unique
  version     Int      @default(1)
  payload     Json
  metrics     Json?
  trainedAt   DateTime @default(now())
  sampleCount Int      @default(0)

  @@index([name])
}

// Training examples accumulated from real conversations and tickets.
// Used to retrain the category/intent classifiers ("learning from conversations").
model TrainingExample {
  id         String   @id @default(uuid())
  text       String   @db.Text
  label      String
  task       String
  source     String   @default("conversation")
  createdAt  DateTime @default(now())

  @@index([task])
  @@index([label])
}

// Self-learning candidate: a proposed knowledge entry derived from a validated,
// non-temporary conversation. Must be reviewed by admin/helpdesk before it can
// become a real KnowledgeDocument used by RAG (PRD section 6.7.6 / 8.8).
model KnowledgeCandidate {
  id               String                   @id @default(uuid())
  sourceSessionId  String?
  createdByUserId  String?
  title            String
  content          String                   @db.Text
  categoryId       String?
  status           KnowledgeCandidateStatus @default(PENDING)
  confidenceScore  Float?
  redactionStatus  RedactionStatus          @default(PENDING)
  reviewNote       String?                  @db.Text
  approvedDocumentId String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([status])
  @@index([sourceSessionId])
}
